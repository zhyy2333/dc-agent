# DeepSeek API (as Anthropic proxy)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-your-key-here
ANTHROPIC_MODEL=deepseek-v4-pro

# Job search defaults
JOB_DEFAULT_CITY=深圳
JOB_DEFAULT_SALARY_MIN=15000
JOB_DEFAULT_SALARY_MAX=35000

# Browser (set to true for headless mode)
BROWSER_HEADLESS=false

# Delays in seconds (anti-bot)
ACTION_DELAY_MIN=1.0
ACTION_DELAY_MAX=3.0
